# .env.example for Wassal Logistics Platform
# Copy this file to `.env` and customize values for your environment.

# Node / Next
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Prisma)
# Local SQLite fallback:
# DATABASE_URL="file:./prisma/dev.db"
# Supabase/Postgres examples:
# Direct database URL (requires IPv6 support):
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
# IPv4-compatible Supabase transaction pooler:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?sslmode=no-verify&pgbouncer=true&connection_limit=1"
DATABASE_URL=""

# Supabase client configuration
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Application secrets
APP_SECRET=changeme_replace_me
HASH_SALT=changeme_salt

# Optional third-party integrations (placeholders)
# WHATSAPP_API_URL=https://api.example.com/whatsapp
# WHATSAPP_API_KEY=your_whatsapp_api_key
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=supersecret
# SENTRY_DSN=

# Notes:
# - Do NOT commit your real `.env` file to version control.
# - For production, use a proper production database and secure values.
